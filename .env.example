# =============================================================================
# Siesel's Website - Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Amplify deployment, set these in the Amplify Console:
#   App settings > Environment variables
# =============================================================================

# Site URL (used for sitemap, robots.txt, and Open Graph metadata)
# Local: http://localhost:3000
# Production: https://www.siesels.com (or your actual domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WooCommerce API base URL (server-side)
# Example: https://your-wordpress-domain.com
WP_API_URL=

# WooCommerce REST API credentials (server-side)
WC_KEY=
WC_SECRET=

# Stripe secret key (server-side)
STRIPE_SECRET_KEY=

# Google Maps API Key (optional - currently using embed URLs which don't require a key)
# Only needed if migrating to the Google Maps JavaScript API
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Future integrations ---

# Legacy CMS Cooking Webservice (server-side)
# Full endpoint shape: {CMS_COOKING_API_BASE_URL}/{CMS_COOKING_API_CLIENT_ID}/{CMS_COOKING_API_KEY}/cooking/
CMS_COOKING_API_BASE_URL=https://siesels.cms.dwgreen.com/webservices
CMS_COOKING_API_CLIENT_ID=SIM
CMS_COOKING_API_KEY=

# Optional override for the full webservice URL if needed.
# Example:
# RECIPE_API_BASE=https://siesels.cms.dwgreen.com/webservices/SIM/<KEY>/cooking/
# RECIPE_API_BASE=

# Recipe rating write path
# - db: keep direct DB writes from the Next.js server (current behavior)
# - webservice: send rating writes to the legacy CMS cooking webservice
RECIPE_RATING_WRITE_MODE=db

# Mailchimp (for newsletter signup form in the footer)
# MAILCHIMP_API_KEY=
# MAILCHIMP_AUDIENCE_ID=

# Instagram Basic Display API (for live Instagram feed)
# INSTAGRAM_ACCESS_TOKEN=
