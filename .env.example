# =============================================================================
# Siesel's Website - Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Amplify deployment, set these in the Amplify Console:
#   App settings > Environment variables
# =============================================================================

# Site URL (used for sitemap, robots.txt, and Open Graph metadata)
# Local: http://localhost:3000
# Production: https://www.siesels.com (or your actual domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps API Key (optional - currently using embed URLs which don't require a key)
# Only needed if migrating to the Google Maps JavaScript API
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Future integrations ---

# Mailchimp (for newsletter signup form in the footer)
# MAILCHIMP_API_KEY=
# MAILCHIMP_AUDIENCE_ID=

# Instagram Basic Display API (for live Instagram feed)
# INSTAGRAM_ACCESS_TOKEN=
